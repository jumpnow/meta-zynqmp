From 23da7b7341e09674694af2c8169bec9cc258dab7 Mon Sep 17 00:00:00 2001
From: Scott Ellis <scott@jumpnowtek.com>
Date: Wed, 16 Jan 2019 12:06:56 -0500
Subject: [PATCH 1/2] Load built-in config object at boot

---
 lib/sw_apps/zynqmp_pmufw/src/pm_binding.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/pm_binding.c b/pm_binding.c
index 9553120..35f995f 100644
--- a/pm_binding.c
+++ b/pm_binding.c
@@ -43,6 +43,9 @@
 #include "pm_extern.h"
 #include "pm_usb.h"
 #include "pm_hooks.h"
+#include "pm_config.h"
+
+extern u32 XPm_ConfigObject[]; /* from pm_cfg_obj.c */
 
 /* All GIC wakes in GPI1 */
 #define PMU_IOMODULE_GPI1_GIC_WAKES_ALL_MASK \
@@ -82,6 +85,7 @@ void XPfw_PmInit(void)
 	if (bootType == PM_COLD_BOOT) {
 		PmMasterDefaultConfig();
 		PmNodeConstruct();
+		PmConfigLoadObject((u32)&XPm_ConfigObject, 0xFFFFFFFFU);
 	}
 }
 
